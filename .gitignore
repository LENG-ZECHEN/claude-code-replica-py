# Autonomous-loop runtime artifacts.
# automation/logs/    — scratch; never committed.
# initiatives/current/logs/  — per-milestone logs of the in-flight initiative;
#                              moved into initiatives/_archive/<slug>/logs/ at
#                              wrap-up time (where they ARE tracked).
automation/logs/
initiatives/current/logs/

# Visibility demo artifacts (M3).
# examples/_artifacts/<run-id>/  — per-run trace/transcript/metrics/summary
#                                  bundles written by visibility_full_demo.py.
#                                  Local-only; never committed.
examples/_artifacts/

# Runtime cache from 'simple-agent' REPL (per-workspace state)
src/simple_coding_agent/.simple-agent/

# Personal job-application docs — kept local only
RESUME.md
VERIFICATION.md
